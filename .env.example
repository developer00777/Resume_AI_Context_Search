# Resume Intelligence Configuration
# ==================================
# Copy this file to .env and fill in your values

# ---- API Authentication ----
# When set, all API requests (except /health) require X-API-Key header.
# Leave empty for local development (auth disabled).
API_KEY=

# ---- LLM Provider (OpenAI-compatible) ----
# OpenRouter is the default for MVP. Swap base URL to Ollama for on-server sovereignty.
# OpenRouter key: https://openrouter.ai/keys
OPENAI_API_KEY=sk-or-v1-your-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Best model for resume entity extraction:
MODEL_NAME=anthropic/claude-sonnet-4

# ---- Neo4j Database ----
# Local Docker: bolt://localhost:7687
# Docker Compose (internal network): bolt://neo4j:7687
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ---- Embedding Provider (OpenAI-compatible) ----
# For sovereignty: point to Ollama running nomic-embed-text on the procured server.
# For MVP: leave unset and it defaults to the OPENAI_* values above.
EMBEDDING_MODEL=openai/text-embedding-3-small
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=http://localhost:11434/v1   # Ollama example

# ---- API Server ----
API_HOST=0.0.0.0
API_PORT=8080
CORS_ORIGINS=
