# Resume Intelligence Configuration
# ==================================
# Copy to .env and fill in your values.
# On Railway: set these as Railway environment variables directly.

# ── API Authentication ──────────────────────────────────────────────────────
# All endpoints except /health require X-API-Key header when this is set.
# Leave empty for local development (auth disabled).
API_KEY=

# ── Neo4j Database ──────────────────────────────────────────────────────────
# Local Docker:                   bolt://localhost:7687
# Docker Compose (internal):      bolt://neo4j:7687
# Railway internal network:       bolt://<neo4j-service>.railway.internal:7687
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ── LLM — Two modes, switch via Railway variables ───────────────────────────
#
# MODE 3: Query / extract via OpenRouter (default)
LLM_API_KEY=sk-or-v1-your-openrouter-key
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=anthropic/claude-sonnet-4
#
# MODE 4: Query / extract via local Ollama (data sovereignty)
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.1:8b

# ── Embeddings — Two modes, independently switchable ────────────────────────
#
# MODE 1: Embed via OpenRouter (default — falls back to LLM_* values if unset)
EMBEDDING_MODEL=openai/text-embedding-3-small
# EMBEDDING_API_KEY=sk-or-v1-your-openrouter-key   # omit to reuse LLM_API_KEY
# EMBEDDING_BASE_URL=https://openrouter.ai/api/v1   # omit to reuse LLM_BASE_URL
#
# MODE 2: Embed via local Ollama (strongest sovereignty — text never leaves server)
# EMBEDDING_API_KEY=ollama
# EMBEDDING_BASE_URL=http://localhost:11434/v1
# EMBEDDING_MODEL=nomic-embed-text

# ── Mix and match freely ─────────────────────────────────────────────────────
# Example: local embeddings (sovereignty) + OpenRouter LLM (better extraction):
#   LLM_API_KEY=sk-or-v1-...
#   LLM_BASE_URL=https://openrouter.ai/api/v1
#   LLM_MODEL=anthropic/claude-sonnet-4
#   EMBEDDING_API_KEY=ollama
#   EMBEDDING_BASE_URL=http://localhost:11434/v1
#   EMBEDDING_MODEL=nomic-embed-text

# ── API Server ───────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080
CORS_ORIGINS=
